# ─── LLM Scoring ─────────────────────────────────────────────────────────────
# OpenRouter (recommended) — leave blank to run fully local with Ollama only
OPENROUTER_API_KEY=
SCORER_MODEL=google/gemini-flash-1.5

# Ollama — leave blank to use OpenRouter only
# macOS + Docker Desktop  → http://host.docker.internal:11434
# Linux                   → http://host-gateway:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral

# ─── App ──────────────────────────────────────────────────────────────────────
FETCH_INTERVAL_MINUTES=720
DB_PATH=/data/makhal.db

# Internal service-to-service secret — change this, never expose it
API_SECRET=changeme_local

# ─── Anti-flood guardrails ────────────────────────────────────────────────────
# Max new articles ingested per feed per poll cycle
MAX_NEW_ARTICLES_PER_FEED=5

# Ignore articles older than N days
MAX_ARTICLE_AGE_DAYS=7

# Delay (seconds) between consecutive LLM scoring calls (rate limiting)
SCORE_DELAY_SECONDS=2.0

# ─── Retention ────────────────────────────────────────────────────────────────
# Max articles kept per feed — oldest read articles are pruned first
MAX_ARTICLES_PER_FEED=200

# Hard-delete articles older than N days (0 = disabled)
ARTICLE_RETENTION_DAYS=90

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED if the app is reachable from the internet

# Set to false for local HTTP development, true (default) for production HTTPS
HTTPS_ONLY=true

# Generate a strong password — example: openssl rand -base64 32
AUTH_PASSWORD=change_me_to_a_strong_password

# CORS origin — must match your public domain exactly (no trailing slash)
CORS_ORIGIN=https://reader.example.com

# ─── Caddy (production only) ──────────────────────────────────────────────────
# Ignored in local dev via docker-compose.override.yml
# Setting this activates automatic HTTPS via Let's Encrypt
CADDY_DOMAIN=reader.example.com
