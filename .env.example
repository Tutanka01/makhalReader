# --- LLM Scoring ---
# OpenRouter : laisser vide pour utiliser uniquement Ollama
OPENROUTER_API_KEY=
SCORER_MODEL=google/gemini-flash-1.5

# Ollama : laisser vide pour utiliser uniquement OpenRouter
# macOS + Docker Desktop → host.docker.internal
# Linux               → http://host-gateway:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral

# --- App ---
FETCH_INTERVAL_MINUTES=15
DB_PATH=/data/makhal.db
API_SECRET=changeme_local

# --- Guardrails anti-flood LLM ---
# Max nouveaux articles ingérés par feed par cycle de poll
MAX_NEW_ARTICLES_PER_FEED=5
# Ignorer les articles plus vieux que N jours
MAX_ARTICLE_AGE_DAYS=7
# Délai (secondes) entre deux appels LLM consécutifs (rate limiting)
SCORE_DELAY_SECONDS=2.0

# --- Rétention DB ---
# Max articles conservés par feed (les plus anciens lus sont supprimés en premier)
MAX_ARTICLES_PER_FEED=200
# Supprimer les articles plus vieux que N jours (0 = désactivé)
ARTICLE_RETENTION_DAYS=90

# --- Auth (REQUIRED for internet exposure) ---
# Set to false for local HTTP development, true (default) for production HTTPS
HTTPS_ONLY=true
# Generate a strong password. Example: openssl rand -base64 32
AUTH_PASSWORD=change_me_to_a_strong_password

# CORS origin — must match your public domain (no trailing slash)
CORS_ORIGIN=https://reader.example.com

# --- Caddy (prod seulement, ignoré en local via docker-compose.override.yml) ---
CADDY_DOMAIN=reader.example.com
